---
import { homeContent } from "../config/home";
import { siteConfig } from "../config/site";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <strong>{siteConfig.name.toUpperCase()}</strong>
      <p>{homeContent.footer.tagline}</p>
    </div>

    <div class="footer-col">
      <p class="label-eyebrow">Visit</p>
      <p>{siteConfig.address.street}</p>
      <p>{siteConfig.address.postalCode} - {siteConfig.address.country}</p>
      <p>{siteConfig.phone}</p>
      <p><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></p>
    </div>

    <div class="footer-col">
      <p class="label-eyebrow">Hours</p>
      <p>{siteConfig.hours.serviceDays}</p>
      <p>{siteConfig.hours.seatings}</p>
      <p>Closed {siteConfig.hours.closed}</p>
    </div>

    <div class="footer-col">
      <p class="label-eyebrow">Elsewhere</p>
      <ul>
        {siteConfig.social.map((item) => (
          <li><a href={item.href} target="_blank" rel="noreferrer">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} {siteConfig.name}. All rights reserved.</p>
      <p><span class="ember-dot" aria-hidden="true"></span> {homeContent.footer.signal}</p>
    </div>
  </div>
</footer>
